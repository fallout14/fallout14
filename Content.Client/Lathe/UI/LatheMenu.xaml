<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:ui="clr-namespace:Content.Client.Materials.UI"
    Title="{Loc 'lathe-menu-title'}"
    MinSize="850 500"
    SetSize="1150 620">
    <!-- #Misfits Change Add: Restructured to 3-section layout: All Items, Craftable Now, Storage & Queue -->
    <BoxContainer
        Orientation="Horizontal"
        VerticalExpand="True"
        HorizontalExpand="True"
        SeparationOverride="5">

        <!-- SECTION 1: Items + Blueprints — separate searchable lists -->
        <BoxContainer
            Orientation="Vertical"
            VerticalExpand="True"
            HorizontalExpand="True"
            SeparationOverride="4"
            SizeFlagsStretchRatio="2">
            <Label
                Text="{Loc 'lathe-menu-all-items-title'}"
                Margin="5 3 5 3"
                HorizontalAlignment="Center"
                FontColorOverride="#AAFFAA"/>
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                <LineEdit
                    Name="SearchBar"
                    PlaceHolder="{Loc 'lathe-menu-search-designs'}"
                    HorizontalExpand="True"/>
                <OptionButton
                    Name="FilterOption"
                    MinWidth="100"
                    StyleClasses="ButtonSquare"/>
            </BoxContainer>
            <PanelContainer VerticalExpand="True" SizeFlagsStretchRatio="1">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#1B1B1E" />
                </PanelContainer.PanelOverride>
                <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
                    <BoxContainer
                        Name="RecipeList"
                        Orientation="Vertical"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        RectClipContent="True"/>
                </ScrollContainer>
            </PanelContainer>

            <Label
                Text="{Loc 'lathe-menu-blueprints-title'}"
                Margin="5 2 5 2"
                HorizontalAlignment="Center"
                FontColorOverride="#FFD9A3"/>
            <LineEdit
                Name="BlueprintSearchBar"
                PlaceHolder="{Loc 'lathe-menu-search-blueprints'}"
                HorizontalExpand="True"/>
            <PanelContainer VerticalExpand="True" SizeFlagsStretchRatio="1">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#1B1B1E" />
                </PanelContainer.PanelOverride>
                <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
                    <BoxContainer
                        Name="BlueprintRecipeList"
                        Orientation="Vertical"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        RectClipContent="True"/>
                </ScrollContainer>
            </PanelContainer>

            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                <Label Margin="8 0 8 0" Text="{Loc 'lathe-menu-amount'}" />
                <LineEdit
                    Name="AmountLineEdit"
                    PlaceHolder="0"
                    Text="1"
                    HorizontalExpand="True" />
            </BoxContainer>
        </BoxContainer>

        <BoxContainer MinWidth="4"/>

        <!-- SECTION 2: Craftable Now — only recipes the player has sufficient materials to build -->
        <BoxContainer
            Orientation="Vertical"
            VerticalExpand="True"
            HorizontalExpand="True"
            SeparationOverride="4"
            SizeFlagsStretchRatio="2">
            <Label
                Text="{Loc 'lathe-menu-craftable-title'}"
                Margin="5 3 5 3"
                HorizontalAlignment="Center"
                FontColorOverride="#AAAAFF"/>
            <PanelContainer VerticalExpand="True">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#1B1B1E" />
                </PanelContainer.PanelOverride>
                <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
                    <!-- BuildableRecipeList auto-populated with recipes that canProduce = true -->
                    <BoxContainer
                        Name="BuildableRecipeList"
                        Orientation="Vertical"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        RectClipContent="True"/>
                </ScrollContainer>
            </PanelContainer>
        </BoxContainer>

        <BoxContainer MinWidth="4"/>

        <!-- SECTION 3: Storage & Queue — materials loaded in the lathe plus the build queue -->
        <BoxContainer
            Orientation="Vertical"
            VerticalExpand="True"
            HorizontalExpand="True"
            SeparationOverride="4"
            SizeFlagsStretchRatio="2">

            <!-- Server list button row -->
            <BoxContainer
                Orientation="Horizontal"
                Align="End"
                HorizontalExpand="True">
                <Button
                    Name="ServerListButton"
                    Text="{Loc 'lathe-menu-server-list'}"
                    TextAlign="Center"
                    Mode="Press"/>
            </BoxContainer>

            <!-- Currently fabricating indicator -->
            <BoxContainer
                Name="FabricatingContainer"
                Orientation="Horizontal"
                HorizontalExpand="True">
                <PanelContainer
                    VerticalExpand="True"
                    HorizontalExpand="True"
                    SizeFlagsStretchRatio="3">
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="#408040" />
                    </PanelContainer.PanelOverride>
                    <Label
                        RectClipContent="False"
                        HorizontalAlignment="Left"
                        Margin="5 0 0 0"
                        Text="{Loc 'lathe-menu-fabricating-message'}"/>
                    <BoxContainer
                        Name="FabricatingDisplayContainer"
                        HorizontalAlignment="Left"
                        Margin="100 0 0 0"/>
                    <Label
                        Name="NameLabel"
                        RectClipContent="True"
                        HorizontalAlignment="Left"
                        Margin="130 0 0 0"/>
                </PanelContainer>
            </BoxContainer>

            <!-- Build queue list -->
            <Label Text="{Loc 'lathe-menu-queue-title'}" Margin="5 4 5 2" HorizontalAlignment="Center"/>
            <ScrollContainer
                MinHeight="80"
                VerticalExpand="True"
                HScrollEnabled="False"
                SizeFlagsStretchRatio="2">
                <BoxContainer
                    Name="QueueList"
                    Orientation="Vertical"
                    HorizontalExpand="True"
                    VerticalExpand="True"
                    RectClipContent="True"/>
            </ScrollContainer>

            <!-- Material storage — shows all materials currently loaded in this workbench -->
            <Label Text="{Loc 'lathe-menu-materials-title'}" Margin="5 5 5 3" HorizontalAlignment="Center"/>
            <BoxContainer
                Orientation="Vertical"
                VerticalExpand="True"
                HorizontalExpand="True"
                SizeFlagsStretchRatio="3">
                <ui:MaterialStorageControl Name="MaterialsList" SizeFlagsStretchRatio="8"/>
            </BoxContainer>

            <!-- Begin DeltaV Additions: Mining points -->
            <BoxContainer Orientation="Horizontal" Name="MiningPointsContainer" Visible="False">
                <Label Name="MiningPointsLabel" HorizontalExpand="True"/>
                <Button Name="MiningPointsClaimButton" Text="{Loc 'lathe-menu-mining-points-claim-button'}"/>
            </BoxContainer>
            <!-- End DeltaV Additions: Mining points -->

        </BoxContainer>

    </BoxContainer>

</DefaultWindow>
