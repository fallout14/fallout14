<!-- #Misfits Add - Dedicated S.P.E.C.I.A.L. allocation window, opened from Character Menu -->
<windows:SpecialWindow
    xmlns="https://spacestation14.io"
    xmlns:windows="clr-namespace:Content.Client.UserInterface.Systems.Character.Windows"
    Title="{Loc 'character-info-special-window-title'}"
    MinWidth="560"
    MinHeight="380">
    <ScrollContainer>
        <BoxContainer Orientation="Vertical" Margin="8">
            <!-- Stat rows are built dynamically in CharacterUIController -->
            <BoxContainer Name="SpecialRows" Access="Public" Orientation="Vertical" SeparationOverride="4"/>
            <!-- Available points counter –– sits between stat rows and action buttons -->
            <Label Name="SpecialPointsLabel" Access="Public" Margin="0 8 0 0"/>
            <!-- Normal action row: Apply and Reset buttons (visible while unconfirmed) -->
            <BoxContainer Name="SpecialButtonRow" Access="Public" Orientation="Horizontal"
                          SeparationOverride="6" HorizontalAlignment="Left" Margin="0 10 0 0">
                <Button Name="SpecialApplyButton" Access="Public" Text="{Loc 'character-info-special-apply'}"/>
                <Button Name="SpecialCancelButton" Access="Public" Text="{Loc 'character-info-special-reset'}"/>
            </BoxContainer>
            <!-- Confirmation row: shown when Apply is clicked, requires explicit confirmation -->
            <BoxContainer Name="SpecialConfirmRow" Access="Public" Orientation="Vertical"
                          Visible="False" Margin="0 10 0 0">
                <Label Text="{Loc 'character-info-special-confirm-warning'}" Modulate="#E87832"
                       HorizontalExpand="True"/>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6" Margin="0 6 0 0">
                    <Button Name="SpecialConfirmYesButton" Access="Public"
                            Text="{Loc 'character-info-special-confirm-yes'}"/>
                    <Button Name="SpecialConfirmNoButton" Access="Public"
                            Text="{Loc 'character-info-special-confirm-no'}"/>
                </BoxContainer>
            </BoxContainer>
            <!-- Locked message: replaces all buttons once allocation is permanently applied -->
            <Label Name="SpecialLockedLabel" Access="Public" Visible="False"
                   Margin="0 10 0 0" Modulate="#888888"
                   Text="{Loc 'character-info-special-locked'}"/>
        </BoxContainer>
    </ScrollContainer>
</windows:SpecialWindow>
