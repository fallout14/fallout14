# #Misfits Add: emote messages for knockdown-causing combat interactions.

# Shown to the attacker when a hit causes a knockdown.
misfits-chat-knockdown-hit = knocks {$target} to the ground

# Shown to the victim when a hit causes a knockdown.
misfits-chat-knockdown-hit-victim = is knocked to the ground by {$user}

# Shown to the attacker when a successful disarm also drops the target.
misfits-chat-disarm-knockdown = knocks {$target} down with a disarm

# Shown to the attacker when a collision knocks the target down.
misfits-chat-collision-knockdown = barges into {$target}, knocking them down

# Shown to the victim when a collision knocks them down.
misfits-chat-collision-knockdown-victim = is knocked down by {$user}'s collision