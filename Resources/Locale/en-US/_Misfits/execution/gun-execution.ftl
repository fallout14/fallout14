# #Misfits Add - Locale strings for gun-based point-blank executions.
# Ported and adapted from Goob-Station.
# All strings receive: $attacker, $victim, $weapon

execution-popup-gun-initial-internal = You press {THE($weapon)} against {POSS-ADJ($victim)} head.
execution-popup-gun-initial-external = {$attacker} presses {POSS-ADJ($attacker)} {$weapon} against the head of {$victim}!

execution-popup-gun-complete-internal = You pull the trigger and end {POSS-ADJ($victim)} suffering.
execution-popup-gun-complete-external = {$attacker} executes {$victim} at point blank range!

execution-popup-gun-empty = *click* — the chamber is empty.

suicide-popup-gun-initial-internal = You press {THE($weapon)} against your own head.
suicide-popup-gun-initial-external = {$attacker} presses {POSS-ADJ($attacker)} {$weapon} against their own head!

suicide-popup-gun-complete-internal = You pull the trigger.
suicide-popup-gun-complete-external = {$attacker} pulls the trigger — ending it all.
