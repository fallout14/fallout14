# #Misfits Add - Locale strings for the player Group system (/group command).
# All keys prefixed with "group-" to avoid collision with upstream keys.

## Command
group-cmd-desc = Open the group panel to form or manage a party.

## Window labels
group-window-title = Group
group-members-header = Members
group-invite-header = Invite Member
group-kick-header = Kick Member
group-no-members-label = You are not in a group.
group-invite-placeholder = Character name…
group-kick-placeholder = Character name…

## Buttons
group-create-button = Create Group
group-invite-button = Invite
group-kick-button = Kick
group-accept-button = Accept
group-decline-button = Decline
group-leave-button = Leave Group
group-disband-button = Disband Group

## Overlay toggle
group-overlay-toggle-label = Show [ALLY] tags over group members

## Pending invite banner
group-invite-pending-label = { $name } has invited you to their group.

## Server feedback — simple
group-already-in-group = You are already in a group.
group-created = Group created.
group-not-in-group = You are not in a group.
group-not-leader = Only the group leader can do that.
group-full = The group is full (max 8 members).
group-invite-expired = That invite has expired.
group-not-found = Group not found.
group-joined = You joined the group.
group-left = You left the group.
group-cannot-kick-self = You cannot kick yourself.
group-you-were-kicked = You were kicked from the group.

## Server feedback — with player name variable
group-player-not-found = No player with the name "{ $name }" was found in the game.
group-target-already-in-group = { $name } is already in a group.
group-invite-sent = Invite sent to { $name }.
group-invite-declined = { $name } declined your invite.
group-target-not-in-group = { $name } is not in your group.
group-kicked = Kicked { $name } from the group.
