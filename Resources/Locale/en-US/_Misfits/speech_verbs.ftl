## Vocal style selector - speech verb names and strings
## Used in the character creation Appearance tab.
## Note: verb strings (rasps, slurs) are new keys; others reuse existing chat-manager.ftl keys.

## Display names shown in the dropdown
chat-speech-verb-name-misfits-rasp = Rasping
chat-speech-verb-name-misfits-squeak = Squeaking
chat-speech-verb-name-misfits-mumble = Mumbling
chat-speech-verb-name-misfits-slur = Slurring
chat-speech-verb-name-misfits-stutter = Stuttering
chat-speech-verb-name-misfits-bellow = Bellowing
chat-speech-verb-name-misfits-croak = Croaking

## Verb strings (the actual word shown in chat, e.g. "John rasps, ...")
chat-speech-verb-misfits-rasp = rasps
chat-speech-verb-misfits-slur = slurs
