## Spirit Board — séance system locale keys.
## Used by SpiritBoardSystem.cs

# Verb shown to shaman/elder on an inactive board
spirit-board-verb-begin = Begin Séance

# Verb shown to shaman/elder on an active board (toggle off)
spirit-board-verb-end = End Séance

# Verb shown to ghosts on an active board within range
spirit-board-verb-commune = Commune with the Living

# Cooldown popup sent to activator when board is still cooling down
spirit-board-cooldown = The spirits need { $seconds } more seconds to rest.

# Atmospheric broadcast to nearby tribe when séance begins
spirit-board-session-started = { $shaman }'s hands hover over the board. A faint chill fills the air...

# Atmospheric broadcast when shaman manually ends the session
spirit-board-session-ended-shaman = The shaman lifts their hands. The séance is over.

# Atmospheric broadcast when a ghost chooses GOODBYE
spirit-board-session-ended-goodbye = The planchette slides to GOODBYE. The spirits depart.

# Atmospheric broadcast when the session times out
spirit-board-session-timeout = The board grows still. The spirits have gone quiet.

# Response popup for a single letter (alphabet selection)
spirit-board-response-letter = A chill hand traces the letter: { $response }

# Response popup for a multi-character word (YES / NO / MAYBE / GOODBYE)
spirit-board-response-word = The planchette drifts to... { $response }

# Ghost-facing BUI window title
spirit-board-window-title = Spirit Board

# Prompt label inside the ghost BUI window
spirit-board-window-prompt = What do the spirits say?

# Label above the alphabet section of the ghost BUI window
spirit-board-window-letters = Spell a letter:
