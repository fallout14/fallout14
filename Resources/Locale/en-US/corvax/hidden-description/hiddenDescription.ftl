corvax-hidden-desc-Hypopen-syndicate = [color=#e31735]This chemistry delivery device disguised as a pen can instantly inject deadly toxins or sedatives into a target.[/color]
corvax-hidden-desc-Hypopen-research = [color=#D381C9]This pen has a hidden reagent container, and the tip is unusually sharp. It looks like a disguised hyposprayer technology.[/color]
corvax-hidden-desc-HypoDart-syndicate = [color=#e31735]This chemistry delivery device disguised as a dart can instantly inject deadly toxins or sedatives into a target.[/color]
corvax-hidden-desc-HypoDart-research = [color=#D381C9]This dart has a hidden reagent container, and the tip is unusually sharp. It looks like a disguised hyposprayer technology.[/color]
corvax-hidden-desc-AgentIDCard-syndicate = [color=#e31735]A syndicate spy device. Allows you to copy access from other ID cards, and calmly configure the name and title of the owner for station identification systems.[/color]
corvax-hidden-desc-AgentIDCard-research = [color=#D381C9]A reprogrammed modification of a standard ID card, in which you can safely change the owner's data. Also has a built-in function to copy access rights from other ID cards.[/color]
corvax-hidden-desc-Chameleon-syndicate = [color=#e31735]Has built-in syndicate technology that allows you to change your appearance.[/color]
corvax-hidden-desc-Chameleon-research = [color=#D381C9]You can find a hidden interface that allows you to selectively change the appearance of an object.[/color]
corvax-hidden-desc-Chameleon-thief = [color=#1c9c51]This item is equipped with very valuable camouflage technology.[/color]
corvax-hidden-desc-ThievingGloves-syndicate = [color=#e31735]A syndicate development aimed at covert theft of valuable items.[/color]
corvax-hidden-desc-ThievingGloves-thief = [color=#1c9c51]High-tech coating allows you to remain unnoticed during pickpocketing.[/color]
corvax-hidden-desc-VoiceMasker-syndicate = [color=#e31735]Allows you to imitate voices, deceiving your victims.[/color]
corvax-hidden-desc-VoiceMasker-research = [color=#D381C9]Has a voice transformation function.[/color]
corvax-hidden-desc-NoSlip-ninja = [color=#14e397]Magnetic footwear. Prevents you from falling to your knees before an enemy.[/color]
corvax-hidden-desc-NoSlip-syndicate = [color=#e31735]Special soles prevent you from shamefully falling on your face during an operation.[/color]
corvax-hidden-desc-NoSlip-research = [color=#D381C9]Soles equipped with fine electromagnets, increasing stability on slippery floors.[/color]
corvax-hidden-desc-StealthBox-syndicate = [color=#e31735]The less it moves, the more invisible it becomes. Great for sabotage.[/color]
corvax-hidden-desc-StealthBox-research = [color=#D381C9]This is definitely not an anomaly. This box is equipped with high-tech camouflage field, stabilizing while stationary.[/color]
corvax-hidden-desc-PenExploding-syndicate = [color=#e31735]A deadly bomb disguised as an innocent pen.[/color]
corvax-hidden-desc-PenExploding-research = [color=#D381C9]Inside this pen is a delayed-action explosive charge.[/color]
corvax-hidden-desc-WetFloorSignMineExplosive-syndicate = [color=#e31735]A deadly bomb disguised as a wet floor warning sign.[/color]
corvax-hidden-desc-WetFloorSignMineExplosive-research = [color=#D381C9]Inside this warning sign is a delayed-action explosive charge.[/color]
corvax-hidden-desc-HolyHandGrenade-syndicate = [color=#e31735]A holy grenade, sowing death in the name of god![/color]
corvax-hidden-desc-HolyHandGrenade-research = [color=#D381C9]Inside this orb is a very powerful explosive charge.[/color]
corvax-hidden-desc-SpiderCharge-ninja = [color=#14e397]Explosions are like the sun. Bright light will illuminate the death of the station.[/color]
corvax-hidden-desc-SpiderCharge-research = [color=#D381C9]This is a dirty bomb. You shouldn't activate it.[/color]
corvax-hidden-desc-Gatfruit-syndicate = [color=#e31735]Gatfruit and its fruits are an excellent way to get a firearm.[/color]
corvax-hidden-desc-Gatfruit-botanist = [color=#9be330]From the fruits of this plant you can grow firearms![/color]
corvax-hidden-desc-EnergySword-syndicate = [color=#e31735]A real energy sword, with which you can deflect bullets and cut people like butter.[/color]
corvax-hidden-desc-EnergySword-security = [color=#DE3A3A]This is not a toy sword! This is a real enemy energy weapon![/color]
corvax-hidden-desc-EnergySword-cargo = [color=#A46106]The hilt is too advanced and ergonomic to be a toy. This is a real weapon.[/color]
corvax-hidden-desc-EnergyCutlass-pirate = [color=#A46106]This is a real deadly energy sword in the style of a boarding cutlass. Perfect for boarding![/color]
corvax-hidden-desc-EnergyCutlass-security = [color=#DE3A3A]This is not a toy cutlass! This is a real enemy energy weapon![/color]
corvax-hidden-desc-EnergyCutlass-cargo = [color=#A46106]The hilt is too advanced and ergonomic to be a toy. This is a real energy weapon.[/color]
corvax-hidden-desc-EnergyDagger-syndicate = [color=#e31735]An inconspicuous energy dagger that leaves no blood. They won't even realize it's a weapon.[/color]
corvax-hidden-desc-EnergyDagger-research = [color=#D381C9]Inside this pen is cleverly disguised an energy weapon. Something like a dagger.[/color]
corvax-hidden-desc-FireAxeFlaming-syndicate = [color=#e31735]A high-temperature energy weapon, inconspicuously built into the blade, can be activated by pressing a button. Time to sow chaos.[/color]
corvax-hidden-desc-FireAxeFlaming-research = [color=#D381C9]An extremely high-temperature energy blade has been built into this axe.[/color]
corvax-hidden-desc-EnergyShield-syndicate = [color=#e31735]A real exotic energy shield. Can fit in a pocket when folded.[/color]
corvax-hidden-desc-EnergyShield-security = [color=#DE3A3A]This is a real enemy energy weapon! Before you is an energy shield![/color]
corvax-hidden-desc-EnergyShield-cargo = [color=#A46106]You're familiar with this technology. This is an energy shield.[/color]
corvax-hidden-desc-IllegalImplants-medical = [color=#52B4E9]Checking the serial numbers, you realize this is an uncertified implanter.[/color]
corvax-hidden-desc-LegalImplants-medical = [color=#52B4E9]Checking the serial numbers, you realize this is a legal, certified implanter.[/color]
corvax-hidden-desc-HoloparasiteInjector-syndicate = [color=#e31735]The most sophisticated work of art, based on nanomachines, allowing the user to become a carrier of the most dangerous holoparasite.[/color]
corvax-hidden-desc-HoloparasiteInjector-research = [color=#D381C9]Before you is an extremely complex technology based on nanomachines. It allows you to create a holoparasite and bind it to a carrier.[/color]
corvax-hidden-desc-HoloClownInjector-syndicate = [color=#e31735]The most hilarious work of art, based on nanomachines, allowing the user to become a carrier of a holoclown.[/color]
corvax-hidden-desc-HoloClownInjector-research = [color=#D381C9]Before you is an extremely funny technology based on nanomachines. It allows you to create a strange holoparasite and bind it to a carrier.[/color]
corvax-hidden-desc-SadTromboneImplanter-research = [color=#D381C9]This is a sad trombone implanter. This implant plays a sad melody when the owner dies.[/color]
corvax-hidden-desc-LightImplanter-research = [color=#D381C9]This is a light implanter. Allows the owner's skin to glow faintly at their discretion.[/color]
corvax-hidden-desc-BikeHornImplanter-research = [color=#D381C9]This is a honk implanter. Allows you to make funny sounds from nowhere.[/color]











































