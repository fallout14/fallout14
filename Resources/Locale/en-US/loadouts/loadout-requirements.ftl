loadout-age-requirement = You must be between { $min } and { $max } years old
loadout-species-requirement = You must be { $species }
loadout-trait-requirement = You must have the trait { $trait }
loadout-backpack-type-requirement = You need to use { $type } as your bag
loadout-clothing-preference-requirement = You must wear { $type }
loadout-job-requirement = You must be one of these professions: { $job }
